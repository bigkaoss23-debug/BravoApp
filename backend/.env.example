# =============================================
# BRAVO AGENTS — Variabili d'ambiente
# Copia questo file in .env e compila i valori
# =============================================

# Claude API (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Groq API — https://console.groq.com (necessario per trascrizione audio Whisper)
GROQ_API_KEY=gsk_...

# Ideogram API — https://ideogram.ai/manage-api
IDEOGRAM_API_KEY=...

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJ...                  # anon/public key
SUPABASE_PUBLISHABLE_KEY=            # opzionale
SUPABASE_SECRET_KEY=                 # service_role key (solo backend)

# Configurazione server
PORT=8000
ENV=development
